# Serveur
PORT=5000
FRONTEND_URL=http://localhost:5173

# Base de données : sqlite3 (défaut) ou mysql2
DB_CLIENT=sqlite3
DB_SQLITE_PATH=./data/udbl.db

# MySQL (si DB_CLIENT=mysql2)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=learning_app

# Auth
JWT_SECRET=ma_chaine_ultra_secrete_12345

# Groq (IA) — clé de test : npm run setup-env
GROQ_API_KEY=

# E-mail (optionnel)
EMAIL_USER=tonemail@gmail.com
EMAIL_PASS=mot_de_passe_application_google

# Twilio SMS (optionnel — rappel programme + séances)
# Compte trial : le numéro destinataire doit être vérifié sur console.twilio.com
# TWILIO_PHONE = votre numéro Twilio au format E.164 (ex: +14155552671)
# Téléphone étudiant : +243854721056 ou 0854721056
APP_TIMEZONE=Africa/Lubumbashi
APP_TIMEZONE_OFFSET=+02:00
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE=+14155552671
# Mode test : true = SMS programme à chaque sauvegarde d'agenda (même numéro pour plusieurs comptes)
SMS_TEST_MODE=true
